# ─────────────────────────────────────────────────────────
# RAG Knowledge Assistant — environment variables
# Copy this file to .env and fill in your keys.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────

# Required: OpenAI API key (for embeddings + LLM)
OPENAI_API_KEY=sk-...

# Optional: swap embeddings provider (openai | huggingface)
# huggingface runs fully offline with sentence-transformers
EMBEDDING_PROVIDER=openai

# Optional: change the LLM model
LLM_MODEL=gpt-4o-mini
